# ============================================================
# Parking Tracker — Environment Variables
# ============================================================
# HOW TO USE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in all values marked "CHANGE THIS"
#   3. Never commit .env to git — it contains secrets
#
# The .gitignore already excludes .env.
# The .dockerignore already excludes .env from the Docker image.
# ============================================================

# --- Django core ---

# Secret key used to sign cookies, sessions, and CSRF tokens.
# CHANGE THIS: generate a real random key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# REQUIRED — generate a unique key before first run:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# WARNING: Never use this placeholder value. A known SECRET_KEY means anyone can
# forge signed cookies, CSRF tokens, and session data.
SECRET_KEY=REPLACE-ME-generate-a-real-secret-key-before-starting

# Debug mode: True shows detailed error pages (stack traces, all local variables,
# all HTTP headers, most Django settings). NEVER set True in staging or production.
# Safe for local Docker development only.
DEBUG=True

# Comma-separated list of hostnames Django will accept requests for.
# Example for production: ALLOWED_HOSTS=parkingtracker.example.com,www.parkingtracker.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL database ---
# These values must match the POSTGRES_* environment variables set on the 'db'
# Docker service in docker-compose.yml.

DB_NAME=parking_tracker
DB_USER=parking_user

# CHANGE THIS: use a strong password in any non-local environment.
DB_PASSWORD=parking_pass

# 'db' is the Docker Compose service name — resolved by Docker's internal DNS.
# Change to 'localhost' if running Django outside Docker against a local Postgres.
DB_HOST=db
DB_PORT=5432

# --- Initial data ---
# Credentials for the default superuser created by:
#   docker-compose exec web python manage.py setup_defaults

# CHANGE THIS: use your real admin email.
DEFAULT_SUPERUSER_EMAIL=admin@example.com

# CHANGE THIS: use a strong password and rotate immediately after first login.
DEFAULT_SUPERUSER_PASSWORD=changeme123
